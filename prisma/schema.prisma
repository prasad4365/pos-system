generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("CASHIER") // ADMIN or CASHIER
  orders    Order[]
  createdAt DateTime @default(now())
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]
}

model Product {
  id         String      @id @default(cuid())
  name       String
  sku        String      @unique
  barcode    String?     @unique
  price      Float
  costPrice  Float
  stock      Int         @default(0)
  categoryId String
  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  updatedAt  DateTime    @updatedAt
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  totalAmount   Float
  payableAmount Float
  paymentMethod String      @default("CASH")
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  items         OrderItem[]
  createdAt     DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
}
